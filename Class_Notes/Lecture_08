# Labels
-   they are "key-value pairs" attached to objects.
-   '''yaml
    metadata:
        labels:
            app: frontend
            env: production
            tier: web
    '''

# Selectors
-   Used to find obejcts with specific labels.
-   '''yaml
    selector:
        matchLabels:
            app: frontend
            env: production
    '''

# Commond Examples:
'''bash

# Get pods with specific label
-   kubectl get pods -l app=nginx

# Get pods with multiple labels
-   kubectl get pods -l app=nginx,env=prod

# Get pods with label 'app'
-   kubectl get pods -l app


# Annotations (Metadata)
-   Non-identifying information (not used for selection).
-   '''yaml
    metadata:
        annotations:
            owner: "devops-team"
            contact: "devops@company.com"
            created-by: "John Doe"
    '''

